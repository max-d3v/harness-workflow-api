# Optional. Defaults to 3000.
PORT=3000

# Required for protected API endpoints. Store the SHA-256 hash here, not the raw
# token clients send in Authorization: Bearer <raw-token>.
CODING_HARNESS_API_TOKEN_SHA256=

# Required for /mode/code-test so the QA agent can post PR comments through the
# GitHub MCP server. The local gh CLI must also be authenticated for PR commands.
GITHUB_TOKEN=
