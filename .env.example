# Optional. Defaults to 3000.
PORT=3000

# Required for protected API endpoints. Clients send this value in
# Authorization: Bearer <token>.
CODING_HARNESS_API_TOKEN=

# Required for /mode/code-test so the QA agent can post PR comments through the
# GitHub MCP server. The local gh CLI must also be authenticated for PR commands.
GITHUB_TOKEN_USER=

# Optional. Defaults to logs/runs.jsonl relative to the process cwd.
HARNESS_TELEMETRY_FILE=
